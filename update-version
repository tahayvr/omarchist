#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'HELP'
Usage:
  ./update-version major
  ./update-version minor
  ./update-version patch
  ./update-version 1.0.2
  ./update-version --version 1.0.2

Note:
  Run this from the project root.

Updates:
  - Cargo.toml
  - src/ui/about_page/about_view.rs
HELP
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || -z "${1:-}" ]]; then
  usage
  exit 0
fi

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
cwd="$(pwd -P)"

# Define file paths
cargo_toml="${cwd}/Cargo.toml"
about_view="${cwd}/src/ui/about_page/about_view.rs"

# Validation
if [[ ! -f "${cargo_toml}" ]]; then
  echo "Error: run this from the project root."
  exit 1
fi

# Extract current version from Cargo.toml
current_version=$(grep -m1 '^version = "[0-9]\+\.[0-9]\+\.[0-9]\+"' "${cargo_toml}" | sed -E 's/.*version = "([0-9]+\.[0-9]+\.[0-9]+)".*/\1/')

if [[ -z "${current_version}" ]]; then
    echo "Error: Could not extract current version from Cargo.toml"
    exit 1
fi

version=""
input="${1:-}"

if [[ "$input" == "major" ]]; then
    echo "Current version: ${current_version}"
    IFS='.' read -r major minor patch <<< "$current_version"
    version="$((major + 1)).0.0"
elif [[ "$input" == "minor" ]]; then
    echo "Current version: ${current_version}"
    IFS='.' read -r major minor patch <<< "$current_version"
    version="${major}.$((minor + 1)).0"
elif [[ "$input" == "patch" ]]; then
    echo "Current version: ${current_version}"
    IFS='.' read -r major minor patch <<< "$current_version"
    version="${major}.${minor}.$((patch + 1))"
else
    case "${input}" in
      --version)
        version="${2:-}"
        ;;
      --*)
        version="${input#--}"
        ;;
      *)
        version="${input}"
        ;;
    esac
fi

if [[ -z "${version}" ]]; then
  echo "Error: missing version."
  usage
  exit 1
fi

if ! [[ "${version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "Error: invalid version '${version}'. Expected format: X.Y.Z"
  exit 1
fi

echo "Updating version to ${version}"

# 1. Update Cargo.toml
# version = "0.8.1"
echo "  Updating Cargo.toml..."
NEW_VERSION="${version}" perl -0777 -i -pe '
  my $v = $ENV{NEW_VERSION};
  s/(\[package\][^\[]*?\bversion\s*=\s*")[^"]*(")/$1$v$2/s
  or die "Failed to update [package].version in Cargo.toml\n";
' "${cargo_toml}"

# 2. Update src/ui/about_page/about_view.rs
# .child("v0.1.0"),
echo "  Updating src/ui/about_page/about_view.rs..."
NEW_VERSION="${version}" perl -0777 -i -pe '
  my $v = $ENV{NEW_VERSION};
  s/(\.id\("omarchist-version"\).*?\.child\("v)\d+\.\d+\.\d+("\))/$1$v$2/s;
' "${about_view}"

echo "Done."
